<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ churchName }}</title>
    <style type="text/css">
        body, table, td, a {
            -ms-text-size-adjust: 100%;
            -webkit-text-size-adjust: 100%;
        }
        table, td {
            mso-table-rspace: 0pt;
            mso-table-lspace: 0pt;
        }
        img {
            -ms-interpolation-mode: bicubic;
            border: 0;
            outline: none;
            text-decoration: none;
            height: auto;
            line-height: 100%;
        }
        body {
            margin: 0 !important;
            padding: 0 !important;
            width: 100% !important;
            background: #eef0f2;
            font-family: Arial, "Helvetica Neue", Helvetica, sans-serif;
            color: #2f3438;
        }
        table {
            border-collapse: collapse !important;
        }
        a {
            color: #1769c2;
        }
    </style>
</head>
<body>
<div style="display:none;max-height:0;max-width:0;opacity:0;overflow:hidden;font-size:1px;line-height:1px;color:#eef0f2;">
    Message from {{ churchName }}.
</div>

<table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%" style="padding: 28px 16px;">
    <tr>
        <td align="center">
            <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%" style="max-width: 760px; background: #f3f4f6;">
                <tr>
                    <td style="padding: 30px 40px 14px 40px;">
                        <table role="presentation" border="0" cellpadding="0" cellspacing="0">
                            <tr>
                                <td style="padding-right: 16px; vertical-align: middle;">
                                    {% if brandLogoUrl %}
                                        <img src="{{ brandLogoUrl }}" alt="Good News badge" width="74" style="display:block; width:74px; max-width:74px;">
                                    {% elseif churchLogo %}
                                        <img src="{{ churchCRMURL }}/{{ churchLogo }}" alt="Logo" width="74" style="display:block; width:74px; max-width:74px;">
                                    {% endif %}
                                </td>
                                <td style="vertical-align: middle; font-size: 20px; line-height: 1.2; font-weight: 700; letter-spacing: -0.2px; color: #111;">
                                    {{ churchName }}
                                </td>
                            </tr>
                        </table>
                    </td>
                </tr>

                {% set recipientFirstName = firstName|default('')|trim %}
                <tr>
                    <td style="padding: 0 40px 18px 40px; font-size: 16px; line-height: 1.3; color: #111;">
                        Hi {{ recipientFirstName != '' ? recipientFirstName : toName }},
                    </td>
                </tr>

                <tr>
                    <td style="padding: 0 40px 40px 40px; font-size: 12px; line-height: 1.65; color: #343a40;">
                        {{ bodyHtml|raw }}
                    </td>
                </tr>

                <tr>
                    <td style="background: #33363a; color: #f1f1f1; text-align: center; padding: 28px 24px; font-size: 14px; line-height: 1.6;">
                        <div style="font-size: 16px; line-height: 1.25; font-weight: 600; margin-bottom: 10px;">{{ churchName }}</div>
                        <div>{{ churchAddress }}</div>
                        <div>{{ churchPhone }}{% if churchEmail %} • <a href="mailto:{{ churchEmail }}" style="color:#b8d7ff;">{{ churchEmail }}</a>{% endif %}</div>
                    </td>
                </tr>
            </table>
        </td>
    </tr>
</table>
</body>
</html>
