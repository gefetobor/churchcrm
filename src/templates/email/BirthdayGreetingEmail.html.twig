<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ churchName }}</title>
    <style type="text/css">
        body, table, td, a {
            -ms-text-size-adjust: 100%;
            -webkit-text-size-adjust: 100%;
        }
        table, td {
            mso-table-rspace: 0pt;
            mso-table-lspace: 0pt;
        }
        body {
            margin: 0 !important;
            padding: 0 !important;
            width: 100% !important;
            background: #f5f6f8;
            font-family: Arial, Helvetica, sans-serif;
            color: #222;
        }
        table {
            border-collapse: collapse !important;
        }
    </style>
</head>
<body>
<table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%" style="padding: 20px 12px;">
    <tr>
        <td align="center">
            <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%" style="max-width: 620px; background: #ffffff; border: 1px solid #e2e5ea;">
                <tr>
                    <td style="padding: 24px 24px 10px 24px; font-size: 16px; line-height: 1.5;">
                        Hi {{ firstName|default(toName) }},
                    </td>
                </tr>
                <tr>
                    <td style="padding: 0 24px 24px 24px; font-size: 15px; line-height: 1.6;">
                        {{ bodyHtml|raw }}
                    </td>
                </tr>
                <tr>
                    <td style="padding: 0 24px 18px 24px; font-size: 13px; line-height: 1.5; color: #555;">
                        {{ churchName }}
                    </td>
                </tr>
            </table>
        </td>
    </tr>
</table>
</body>
</html>
