# Copy to .env.prod and replace placeholder values.

TZ=Europe/London

# Public domain and certificate email for Caddy
DOMAIN=spiritembassyleeds.co.uk
ACME_EMAIL=admin@spiritembassyleeds.co.uk

# ChurchCRM URL settings used by docker-entrypoint.sh
APP_URL=https://spiritembassyleeds.co.uk/
APP_ROOT_PATH=

# Database settings
DB_NAME=churchcrm
DB_USER=churchcrm
DB_PASSWORD=change_this_db_password
MYSQL_ROOT_PASSWORD=change_this_root_password
